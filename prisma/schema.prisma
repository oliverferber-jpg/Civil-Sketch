generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  googleSub String?  @unique
  createdAt DateTime @default(now())
  projects  Project[]
}

model Project {
  id          String   @id @default(uuid())
  ownerId     String
  name        String
  description String?
  folder      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  owner       User     @relation(fields: [ownerId], references: [id])
  drawings    Drawing[]
}

model Drawing {
  id          String   @id @default(uuid())
  projectId   String
  title       String
  angle       String?
  status      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  project     Project  @relation(fields: [projectId], references: [id])
  versions    DrawingVersion[]
  assets      DrawingAsset[]
}

model DrawingVersion {
  id            String   @id @default(uuid())
  drawingId     String
  versionNumber Int
  payloadJson   Json
  createdAt     DateTime @default(now())
  drawing       Drawing  @relation(fields: [drawingId], references: [id])
}

model DrawingAsset {
  id           String   @id @default(uuid())
  drawingId    String
  fileType     String
  storageKey   String
  originalName String?
  mimeType     String?
  sizeBytes    Int?
  createdAt    DateTime @default(now())
  drawing      Drawing  @relation(fields: [drawingId], references: [id])
}
