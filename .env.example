# Frontend vars (Vite) go in .env.local — copy this section there.
#
# Google OAuth Client ID (safe to expose to the frontend, not a secret).
# Get this from Google Cloud Console > APIs & Services > Credentials >
# OAuth 2.0 Client ID (type: Web application), with http://localhost:5173
# added as an authorized JavaScript origin.
#
# Without it, the app falls back to a demo sign-in button.
VITE_GOOGLE_CLIENT_ID=

# Backend API base URL
VITE_API_BASE_URL=http://localhost:3000

# Backend vars go in a plain .env (not .env.local) — prisma.config.ts loads
# `.env` via `dotenv/config`, and `npm run dev:server` loads it via Node's
# `--env-file=.env` flag. A Neon (or other Postgres) connection string:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/civilsketch
